# MongoDB Connection String
# Get this from MongoDB Atlas: https://cloud.mongodb.com/
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
DATABASE_URL=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/brainout

# Server Port
# Port on which the Express server will listen
PORT=3000

# JWT Secret Key
# Generate a strong random string for JWT token signing
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
USER_SECRET_KEY=your-secret-key-here-make-it-long-and-random

# Bcrypt Salt Rounds
# Number of salt rounds for bcrypt password hashing (10-12 recommended)
SALTROUND=10
